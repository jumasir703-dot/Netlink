# ===== Server =====
PORT=4000
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password
JWT_SECRET=change-this-to-a-long-random-string

# ===== MikroTik RouterOS API =====
# Enable the API service on your router first: /ip service enable api (port 8728)
# or api-ssl (port 8729) for encrypted connections.
MIKROTIK_HOST=192.168.88.1
MIKROTIK_USER=admin
MIKROTIK_PASSWORD=your-router-password
MIKROTIK_PORT=8728
MIKROTIK_USE_SSL=false

# ===== Safaricom Daraja M-Pesa =====
# Get these from https://developer.safaricom.co.ke after creating an app
MPESA_ENV=sandbox
# sandbox | production
MPESA_CONSUMER_KEY=your-consumer-key
MPESA_CONSUMER_SECRET=your-consumer-secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your-lipa-na-mpesa-online-passkey
MPESA_CALLBACK_URL=https://yourdomain.com/api/mpesa/callback
